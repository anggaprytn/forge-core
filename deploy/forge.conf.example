# Required
storage_root=/var/lib/forge
api_bind=127.0.0.1:8080
# bootstrap/admin token; prefer CLI tokens for routine remote operation
bearer_token=replace-with-a-long-random-token

# Optional
# repository_cache_root=/var/cache/forge/repositories
# github_webhook_secret=replace-with-a-webhook-secret
# release_public_key_path=/etc/forge/release-public-key.pem
# sqlite_path=/var/lib/forge/forge.sqlite
#
# Set ALLOW_NEW_REGISTRATION in /etc/forge/forge.env for initial GitHub OAuth bootstrap.
# Example:
# ALLOW_NEW_REGISTRATION=true
# Log in once, then set ALLOW_NEW_REGISTRATION=false and restart Forge.

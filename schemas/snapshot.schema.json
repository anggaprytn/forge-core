{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/snapshot.schema.json",
  "title": "Forge Generation Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_version",
    "project_id",
    "environment",
    "generation",
    "state",
    "finalized_at_unix"
  ],
  "properties": {
    "snapshot_version": {
      "const": 1
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "environment": {
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "generation": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "enum": [
        "healthy",
        "degraded",
        "failed",
        "stopped",
        "rollback"
      ]
    },
    "finalized_at_unix": {
      "type": "integer"
    }
  }
}

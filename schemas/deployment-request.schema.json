{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/deployment-request.schema.json",
  "title": "Forge Deployment Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "environment",
    "intent"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "environment": {
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,64}$"
    },
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "intent": {
      "enum": [
        "deploy",
        "redeploy",
        "rollback"
      ]
    },
    "runtime_override": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "required": [
          "commit_sha",
          "image_digest"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "const": "rollback"
          }
        }
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "commit_sha"
              ]
            },
            {
              "required": [
                "image_digest"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "enum": [
              "deploy",
              "redeploy"
            ]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "commit_sha"
            ]
          },
          {
            "required": [
              "image_digest"
            ]
          }
        ]
      }
    }
  ]
}

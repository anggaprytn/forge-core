{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/deployment-request.schema.json",
  "title": "Forge Deployment Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "environment",
    "intent"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "environment": {
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "intent": {
      "enum": [
        "deploy",
        "redeploy",
        "rollback"
      ]
    }
  }
}

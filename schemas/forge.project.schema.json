{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/forge.project.schema.json",
  "title": "Forge Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_variables"
      ],
      "properties": {
        "environment_variables": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/secretReference"
          }
        }
      }
    }
  },
  "$defs": {
    "secretReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "key"
      ],
      "properties": {
        "scope": {
          "enum": ["environment"]
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "sensitive": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}

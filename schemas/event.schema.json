{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/schemas/event.schema.json",
  "title": "Forge Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timestamp_unix",
    "project_id",
    "environment",
    "event_type"
  ],
  "properties": {
    "timestamp_unix": {
      "type": "integer"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "environment": {
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "generation": {
      "type": "integer",
      "minimum": 1
    },
    "deployment_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "REQUIRED_SECRET_MISSING",
        "DEPLOYMENT_STARTED",
        "IMAGE_BUILT",
        "RUNTIME_ENV_PREPARED",
        "CONTAINER_STARTED",
        "SNAPSHOT_FINALIZED",
        "GENERATION_PROMOTED",
        "VALIDATION_PASSED",
        "GENERATION_FAILED",
        "TCP_PROBE_FAILED",
        "HTTP_PROBE_FAILED",
        "FAILED_GENERATION_TOMBSTONED",
        "FAILED_GENERATION_CLEANED",
        "ROLLBACK_COMPLETED"
      ]
    },
    "reason": {
      "type": "string"
    }
  }
}

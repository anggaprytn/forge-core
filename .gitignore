# ==========================================
# Rust / Cargo
# ==========================================
/target/
**/*.rs.bk

# Cargo.lock is tracked for applications to ensure deterministic builds.
# !Cargo.lock

# ==========================================
# Frontend / Node
# ==========================================
node_modules/
dist/
.output/
.build/
.next/
.html/
.vinxi/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Forge Platform Runtime & Local Ledger
# ==========================================
# Do not commit local state, snapshots, or container data.
/var/lib/forge/
data/
snapshots/
tmp/
*.db
*.db-journal
*.db-wal
*.db-shm

# ==========================================
# Security, Secrets & Local Environments
# ==========================================
# Forge encryption keys and local environment variables must be ignored.
.env
.env.local
.env.*.local
*.pem
*.key
FORGE_MASTER_KEY

# ==========================================
# IDEs & System Garbage
# ==========================================
.DS_Store
.idea/
.vscode/
*.suo
*.swp
*~
.direnv/
.envrc
